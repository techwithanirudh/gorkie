# Copy to .env and fill in your secrets (.env is gitignored).

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
NODE_ENV="development"

# ----------------------------------------------------------------------------
# Slack
# ----------------------------------------------------------------------------
# App-level token for Socket Mode (connections:write). https://api.slack.com/apis/connections/socket
SLACK_APP_TOKEN="xapp-your-app-token"
# Bot User OAuth Token (OAuth & Permissions)
SLACK_BOT_TOKEN="xoxb-your-bot-token"
# Signing secret (Basic Information). Not required for Socket Mode.
SLACK_SIGNING_SECRET="your-signing-secret"
# Optional opt-in allowlist gate: when set, only members of this channel may use
# gorkie (see terms-of-service-by-channel-membership pattern in lib/allowed-users.ts).
# Leave unset to allow everyone.
OPT_IN_CHANNEL="C0123ABCDEF"

# Optional comma-separated list of Slack channel ids that `leave_channel` must
# refuse to leave, even when a user explicitly asks. Use this to protect
# admin/control channels (e.g. the channel where gorkie is operated from)
# from being left. Leave unset to allow leaving any channel.
LEAVE_CHANNEL_BLOCKLIST="C0123ABCDEF,C0A6C5F52BE"

# ----------------------------------------------------------------------------
# Models
# ----------------------------------------------------------------------------
HACKCLUB_API_KEY="sk-hc-your-hackclub-api-key"

# Openrouter
OPENROUTER_API_KEY="sk-or-your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Opencode Go
OPENCODE_API_KEY="your-opencode-api-key"

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/gorkie"

# ----------------------------------------------------------------------------
# Code Sandbox (E2B). https://e2b.dev/
# ----------------------------------------------------------------------------
E2B_API_KEY="your-e2b-api-key"

# Optional brokered sandbox credentials. These stay on the host and are injected
# into outbound sandbox requests with E2B network rules.
AGENTMAIL_API_KEY="your-agentmail-api-key"
GITHUB_TOKEN="ghp-your-github-token"

# ----------------------------------------------------------------------------
# Observability (Mastra Platform). https://mastra.ai/
# ----------------------------------------------------------------------------
MASTRA_PLATFORM_ACCESS_TOKEN="your-mastra-platform-access-token"
MASTRA_PROJECT_ID="your-mastra-project-id"

# ----------------------------------------------------------------------------
# Web search (Exa). https://exa.ai/
# ----------------------------------------------------------------------------
EXA_API_KEY="your-exa-api-key"
