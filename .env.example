# Slack — create the app from a manifest, enable Socket Mode.
SLACK_BOT_TOKEN=xoxb-...          # Bot User OAuth Token (OAuth & Permissions)
SLACK_APP_TOKEN=xapp-...          # App-Level Token with connections:write (Socket Mode)

# Model — Mastra's built-in `openrouter` provider.
# Hack Club's AI proxy is OpenRouter-compatible: point the base URL at it and use
# a Hack Club key. To use real OpenRouter instead, drop OPENROUTER_BASE_URL.
OPENROUTER_API_KEY=sk-hc-v1-...
OPENROUTER_BASE_URL=https://ai.hackclub.com/proxy/v1

# Optional — sandbox provider for Phase 3 (E2B). Unused until then.
# E2B_API_KEY=e2b_...

NODE_ENV=development
